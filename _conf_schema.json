{
  "mail_accounts": {
    "type": "template_list",
    "description": "邮箱账户列表",
    "hint": "添加你要监控的邮箱账户，支持 Gmail、杭电邮箱、QQ 邮箱等所有支持 IMAP 的邮箱",
    "templates": {
      "imap_account": {
        "name": "IMAP 邮箱账户",
        "hint": "填写邮箱的 IMAP 连接信息",
        "items": {
          "name": {
            "description": "账户备注名",
            "type": "string",
            "default": "",
            "hint": "例如：谷歌邮箱、QQ邮箱、工作邮箱"
          },
          "imap_server": {
            "description": "IMAP 服务器地址",
            "type": "string",
            "default": "",
            "hint": "例如：imap.gmail.com、imap.qq.com"
          },
          "imap_port": {
            "description": "IMAP 端口",
            "type": "int",
            "default": 993,
            "hint": "SSL 连接通常为 993"
          },
          "email": {
            "description": "邮箱地址",
            "type": "string",
            "default": ""
          },
          "password": {
            "description": "密码或应用专用密码",
            "type": "string",
            "default": "",
            "hint": "当邮箱服务要求时，请填写授权码或应用专用密码"
          },
          "smtp_server": {
            "description": "SMTP 服务器地址",
            "type": "string",
            "default": "",
            "hint": "例如：smtp.gmail.com、smtp.qq.com"
          },
          "smtp_port": {
            "description": "SMTP 端口",
            "type": "int",
            "default": 465,
            "hint": "SSL 常用 465，STARTTLS 常用 587"
          },
          "smtp_use_ssl": {
            "description": "SMTP 使用 SSL 连接",
            "type": "bool",
            "default": true,
            "hint": "为 false 时将使用 STARTTLS"
          },
          "smtp_password": {
            "description": "SMTP 密码或应用专用密码",
            "type": "string",
            "default": "",
            "hint": "留空时默认复用上方的 IMAP 密码"
          },
          "use_ssl": {
            "description": "IMAP 使用 SSL 连接",
            "type": "bool",
            "default": true
          }
        }
      }
    }
  },
  "check_interval": {
    "description": "检查间隔（分钟）",
    "type": "int",
    "default": 5,
    "hint": "每隔多少分钟检查一次新邮件，建议不低于 2 分钟"
  },
  "display_timezone": {
    "description": "通知显示时区",
    "type": "string",
    "default": "Asia/Shanghai",
    "hint": "使用 IANA 时区名称，例如 Asia/Shanghai、America/New_York、Europe/London；默认显示北京时间"
  },
  "admin_uids": {
    "description": "管理员 UID 列表",
    "type": "list",
    "default": [],
    "hint": "只有列表中的用户可以使用插件命令"
  },
  "notify_umo": {
    "description": "通知目标会话 ID",
    "type": "string",
    "default": "",
    "hint": "可以通过 /mail_bind 绑定，也可以手动填写 unified_msg_origin"
  },
  "ai_summary": {
    "description": "启用 AI 摘要",
    "type": "bool",
    "default": false,
    "hint": "启用后将先生成简短摘要，再发送邮件通知"
  },
  "blacklist_settings": {
    "description": "黑名单设置",
    "type": "object",
    "items": {
      "enable": {
        "description": "启用黑名单过滤",
        "type": "bool",
        "default": false,
        "hint": "开启后，命中发件人、主题或正文任意黑名单规则的邮件不会推送"
      },
      "sender_rules": {
        "description": "发件人规则",
        "type": "list",
        "default": [],
        "hint": "支持完整邮箱、@域名后缀，或普通关键词包含匹配"
      },
      "subject_rules": {
        "description": "主题规则",
        "type": "list",
        "default": [],
        "hint": "使用不区分大小写的包含匹配"
      },
      "body_rules": {
        "description": "正文规则",
        "type": "list",
        "default": [],
        "hint": "使用不区分大小写的包含匹配"
      }
    }
  },
  "whitelist_settings": {
    "description": "白名单设置",
    "type": "object",
    "items": {
      "enable": {
        "description": "启用白名单过滤",
        "type": "bool",
        "default": false,
        "hint": "开启后，只有命中至少一条白名单规则的邮件才会推送"
      },
      "sender_rules": {
        "description": "发件人规则",
        "type": "list",
        "default": [],
        "hint": "支持完整邮箱、@域名后缀，或普通关键词包含匹配"
      },
      "subject_rules": {
        "description": "主题规则",
        "type": "list",
        "default": [],
        "hint": "使用不区分大小写的包含匹配"
      },
      "body_rules": {
        "description": "正文规则",
        "type": "list",
        "default": [],
        "hint": "使用不区分大小写的包含匹配"
      }
    }
  },
  "max_body_length": {
    "description": "通知预览最大长度",
    "type": "int",
    "default": 500,
    "hint": "通知中展示的正文字符上限，也会用于 AI 摘要输入"
  },
  "filter_body_length": {
    "description": "正文过滤最大长度",
    "type": "int",
    "default": 3000,
    "hint": "用于正文黑白名单匹配的最大字符数"
  }
}
